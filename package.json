{
  "name": "recall",
  "version": "0.1.0",
  "description": "Query and analyze AI coding assistant session history",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "bin": {
    "recall": "src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile bin/recall",
    "check": "bun run --bun tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "commander": "^14.0.3",
    "duckdb": "^1.4.4",
    "smol-toml": "^1.6.0"
  }
}
